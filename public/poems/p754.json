[{"title":"调笑转踏・调笑令","lines":["归去。","携笼女。","南陌柔桑三月暮。","使君春思如飞絮。","五马徘徊频驻。","蚕饥日晚空留顾。","笑指秦楼归去。"]},{"title":"调笑转踏・调笑令","lines":["双桨。","小舟荡。","唤取莫愁迎叠浪。","武陵豪客青楼上。","不道风高江广。","千金难买倾城样。","那听绕梁清唱。"]},{"title":"调笑转踏・调笑令","lines":["草草。","最年少。","袖户银屏人窈窕。","瑶琴暗写相思调。","一曲关心多少。","临邛客舍成都道。","苦恨相逢不早。"]},{"title":"调笑转踏・调笑令","lines":["烟暖。","武陵晚。","洞里春长花烂熳。","红英满地溪流浅。","渐听云中鸡犬。","刘朗迷路香风远。","误到蓬莱仙馆。"]},{"title":"调笑转踏・调笑令","lines":["春艳。","桃花脸。","笑倚银屏施宝靥。","良人少有平戎胆。","归路光生弓剑。","青楼春永香帏掩。","独把韶华都占。"]},{"title":"调笑转踏・调笑令","lines":["相慕。","酒家女。","巧笑明眸年十五。","当垆春永寻芳去。","门外落花飞絮。","银鞍白马金吾子。","多谢结裙情素。"]},{"title":"调笑转踏・调笑令","lines":["肠断。","浙江岸。","楼上青帘新酒软。","吴姬绰约开金盏。","的的娇波流盼。","采菱歌罢行云散。","望断侬家心眼。"]},{"title":"调笑转踏・调笑令","lines":["苏小。","最娇妙。","几度尊前曾调笑。","云情雨态知多少。","悔恨相逢不早。","刘郎襟韵正年少。","风月今宵偏好。"]},{"title":"调笑转踏・调笑令","lines":["梦悄。","翠屏晓。","帐里薰炉残蜡照。","赏心乐事能多少。","忍听阳关声调。","明朝门外长安道。","怅望王孙芳草。"]},{"title":"调笑转踏・调笑令","lines":["时节。","白银阙。","洞里春晴百和爇。","兰心底事多悲切。","消尽一团冰雪。","明皇恩爱云山绝。","谁道蓬莱安悦。"]},{"title":"调笑转踏・调笑令","lines":["调笑。","楚江渺。","粉面修眉花斗好。","擎荷折柳争相调。","惊起鸳鸯多少。","渔歌齐唱催残照。","一叶归舟轻小。"]},{"title":"调笑转踏・调笑令","lines":["声切。","恨难说。","千里潮平春浪阔。","梅风不解相思结。","忍送落花飞雪。","多才一去芳音绝。","更对珠帘新月。"]}]